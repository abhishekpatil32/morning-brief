# Copy this to .env and fill in your values, then:
# chmod 600 .env
#
# Lines starting with # are comments and ignored.

# ----- LLM provider credentials -----
#
# Anthropic provider:
# Required when config.yaml has:
#   backend: api
#   provider: anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible provider:
# Required when config.yaml has:
#   backend: api
#   provider: openai-compatible
#
# This can be an OpenAI key or another provider key if that provider exposes
# an OpenAI-compatible /v1/chat/completions endpoint.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Examples:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=https://api.cerebras.ai/v1
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Ollama provider:
# Usually no API key is needed.
OLLAMA_BASE_URL=http://localhost:11434

# Claude Code provider:
# No env var needed. Install Claude Code and run `claude login`.

# ----- Email / SMTP -----
#
# For Gmail, generate an App Password, not your normal password.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=you@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=you@gmail.com

# Other SMTP providers:
# Outlook: SMTP_SERVER=smtp-mail.outlook.com SMTP_PORT=587
# iCloud:  SMTP_SERVER=smtp.mail.me.com SMTP_PORT=587
# Yahoo:   SMTP_SERVER=smtp.mail.yahoo.com SMTP_PORT=587
