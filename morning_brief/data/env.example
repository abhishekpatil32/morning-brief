# Copy this to .env and fill in your values, then: chmod 600 .env
# Lines starting with # are comments and ignored.

# ----- Anthropic / Claude -----
# Only ONE of these is required, depending on what you set as `backend` in config.yaml.

# Required if backend = "api"
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Required if backend = "claude-code"
# Install Claude Code first: npm install -g @anthropic-ai/claude-code
# Then run `claude login` once -- no env var needed.

# ----- Email (Gmail by default) -----
# For Gmail, generate an App Password (not your normal password):
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password:     https://myaccount.google.com/apppasswords

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=you@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=you@gmail.com

# ----- Other providers -----
# Outlook:  SMTP_SERVER=smtp-mail.outlook.com   SMTP_PORT=587
# iCloud:   SMTP_SERVER=smtp.mail.me.com        SMTP_PORT=587 (app-specific password)
# Yahoo:    SMTP_SERVER=smtp.mail.yahoo.com     SMTP_PORT=587 (app password)
